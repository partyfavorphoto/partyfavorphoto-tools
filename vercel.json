{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "site/public" }
    }
  ],
  "routes": [
    {
      "src": "/book",
      "dest": "/book.html"
    },
    {
      "src": "/(.*)",
      "dest": "/site/public/$1"
    }
  ]
}
